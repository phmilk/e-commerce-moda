# ---------------------------------------------------------------------------
# Template de ambiente. Copie para .env.local (pnpm local) ou .env (docker).
# Ambos os arquivos estão gitignored.
# ---------------------------------------------------------------------------

# Banco (consumido pelo docker-compose para construir a URL e subir o Postgres)
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432
APP_PORT=3000

# DATABASE_URL é consumida pelos scripts locais (pnpm db:*, pnpm dev).
# No docker-compose ela é derivada dos POSTGRES_* acima com hostname "db".
DATABASE_URL=postgresql://ecommerce:ecommerce@localhost:5432/ecommerce

# Better Auth
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET= # pnpm dlx @better-auth/cli secret
